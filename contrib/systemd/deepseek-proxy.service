[Unit]
Description=DeepSeek Reasoning Content Proxy for opencode
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /path/to/deepseek-reasoning-proxy/proxy.py --port 18200 --upstream https://api.deepseek.com
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
